* text=auto eol=lf

# Source files
*.kt            text eol=lf diff=kotlin
*.kts           text eol=lf diff=kotlin
*.java          text eol=lf diff=java
*.groovy        text eol=lf diff=java
*.scala         text eol=lf diff=java
*.gradle        text eol=lf diff=java
*.gradle.kts    text eol=lf diff=kotlin

# Web / frontend
*.html          text eol=lf diff=html
*.htm           text eol=lf diff=html
*.css           text eol=lf diff=css
*.scss          text eol=lf diff=css
*.sass          text eol=lf
*.js            text eol=lf
*.mjs           text eol=lf
*.cjs           text eol=lf
*.json          text eol=lf
*.jsp           text eol=lf
*.jspf          text eol=lf
*.jspx          text eol=lf

# Config / docs
*.md            text eol=lf
*.txt           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.toml          text eol=lf
*.xml           text eol=lf
*.properties    text eol=lf
*.sql           text eol=lf
*.py            text eol=lf
*.df            text eol=lf
*.tld           text eol=lf
*.tag           text eol=lf
*.tagx          text eol=lf
*.editorconfig  text eol=lf

# Build-tool wrappers
mvnw            text eol=lf
gradlew         text eol=lf

# Windows-specific
*.bat           text eol=crlf
*.cmd           text eol=crlf

# Binary files (no text conversion, no diff)
*.class         binary
*.dll           binary
*.ear           binary
*.jar           binary
*.so            binary
*.war           binary
*.jks           binary
